// ============================================================================
// ALGOTREND FULL STRATEGY WITH WEBHOOK INTEGRATION
// By: GonOvi  |  Enhanced for SOSO BTC MAGNET
// ============================================================================
// Paste this ENTIRE script into TradingView Pine Editor.
// ============================================================================

// ═══════════════════════════════════════════════════════════════════════════
// STRATEGY SETTINGS
// ═══════════════════════════════════════════════════════════════════════════
strategy("SOSO BTC MAGNET — AlgoTrend Strategy", overlay=true, max_bars_back=2000,
         initial_capital=10000, default_qty_type=strategy.percent_of_equity,
         default_qty_value=100, commission_type=strategy.commission.percent,
         commission_value=0.075, slippage=1)

// ═══════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════
groupMain     = "AlgoTrend Settings"
groupRisk     = "Risk Management"
groupWebhook  = "WEBHOOK — SOSO BTC MAGNET"

// Main
p1              = input.int(1, "Fast Period", minval=1, group=groupMain)
p2              = input.int(2, "Slow Period", minval=1, group=groupMain)
signalPeriod    = input.int(3, "Signal Period", minval=1, group=groupMain)
showSignals     = input.bool(true, "Show Signals", group=groupMain)
showBackground  = input.bool(true, "Show Background Color", group=groupMain)

// Risk
slPercent       = input.float(2.0, "Stop Loss %", minval=0.1, step=0.1, group=groupRisk)
tpPercent       = input.float(3.0, "Take Profit %", minval=0.1, step=0.1, group=groupRisk)
trailingStop    = input.bool(false, "Use Trailing Stop", group=groupRisk)

// Webhook
webhookUrl      = input.string("", "Webhook URL", tooltip="MUST end with /webhook", group=groupWebhook)
webhookSecret   = input.string("ragnar", "Webhook Secret", group=groupWebhook)
webhookAmount   = input.float(0.05, "Lot Size", minval=0.01, step=0.01, group=groupWebhook)

// ═══════════════════════════════════════════════════════════════════════════
// CALCULATIONS
// ═══════════════════════════════════════════════════════════════════════════
src = close
// Fast EMA
ema1 = ta.ema(src, p1)
// Slow EMA
ema2 = ta.ema(src, p2)
// Signal line (EMA of difference)
macd = ema1 - ema2
signal = ta.ema(macd, signalPeriod)

// Trend direction
bullish = macd > signal
bearish = macd < signal

// Cross detections
crossUp = ta.crossover(macd, signal)
crossDown = ta.crossunder(macd, signal)

// Signals (with bar confirmation to avoid repaint)
signal_long = crossUp and barstate.isconfirmed
signal_short = crossDown and barstate.isconfirmed

// Price levels
sl_price_long = close * (1 - slPercent/100)
tp_price_long = close * (1 + tpPercent/100)
sl_price_short = close * (1 + slPercent/100)
tp_price_short = close * (1 - tpPercent/100)

// ═══════════════════════════════════════════════════════════════════════════
// STRATEGY EXECUTION
// ═══════════════════════════════════════════════════════════════════════════
if signal_long
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=sl_price_long, limit=tp_price_long)

if signal_short
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=sl_price_short, limit=tp_price_short)

// ═══════════════════════════════════════════════════════════════════════════
// VISUALS
// ═══════════════════════════════════════════════════════════════════════════
plot(ema1, color=color.new(#26a69a, 0), title="Fast EMA", linewidth=2)
plot(ema2, color=color.new(#ef5350, 0), title="Slow EMA", linewidth=2)

// Background color for trend
bgColor = bullish ? color.new(#26a69a, 90) : color.new(#ef5350, 90)
bgcolor(showBackground ? bgColor : na)

// Signals
plotshape(signal_long and showSignals, title="Long", style=shape.triangleup,
          location=location.belowbar, color=#26a69a, size=size.normal, text="BUY")
plotshape(signal_short and showSignals, title="Short", style=shape.triangledown,
          location=location.abovebar, color=#ef5350, size=size.normal, text="SELL")

// ═══════════════════════════════════════════════════════════════════════════
// WEBHOOK INTEGRATION — SOSO BTC MAGNET
// ═══════════════════════════════════════════════════════════════════════════
//  IMPORTANT: Your TradingView Alert Webhook URL MUST end with /webhook
//  WRONG:  https://btc-trader-e2t9.onrender.com
//  RIGHT:  https://btc-trader-e2t9.onrender.com/webhook
// ═══════════════════════════════════════════════════════════════════════════

if signal_long and barstate.isconfirmed and webhookUrl != ""
    string json_long = '{"secret":"' + webhookSecret + '","symbol":"' + syminfo.ticker + '","side":"buy","amount":' + str.tostring(webhookAmount) + ',"sl":' + str.tostring(sl_price_long) + ',"tp":' + str.tostring(tp_price_long) + ',"message":"SOSO Long"}'
    alert(json_long, alert.freq_once_per_bar)

if signal_short and barstate.isconfirmed and webhookUrl != ""
    string json_short = '{"secret":"' + webhookSecret + '","symbol":"' + syminfo.ticker + '","side":"sell","amount":' + str.tostring(webhookAmount) + ',"sl":' + str.tostring(sl_price_short) + ',"tp":' + str.tostring(tp_price_short) + ',"message":"SOSO Short"}'
    alert(json_short, alert.freq_once_per_bar)

// ═══════════════════════════════════════════════════════════════════════════
